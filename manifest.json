{
  "name": "Emoji Copy",
  "description": "Uma extensão simples do Chrome para copiar emojis para a área de transferência",
  "version": "1.0",
  "manifest_version": 3,
   "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "./popup/popup.html"
  }
}